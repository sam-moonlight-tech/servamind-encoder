    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "fflate": "^0.8.2",
    "framer-motion": "^12.34.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0",
    "tailwind-merge": "^3.4.0",
